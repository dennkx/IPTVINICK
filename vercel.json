{
  "rewrites": [
    {
      "source": "/iptv-proxy/:path*",
      "destination": "http://hightechtvr1.online/:path*"
    },
    {
      "source": "/hls/:path*",
      "destination": "http://hightechtvr1.online/hls/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
